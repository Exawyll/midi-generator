# Copy this file to .env and fill in your values
# The backend reads ANTHROPIC_API_KEY from the environment at startup.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model (default: claude-sonnet-4-6)
# Use claude-opus-4-6 for richer, more creative arrangements (slower + more expensive)
# CLAUDE_MODEL=claude-opus-4-6
