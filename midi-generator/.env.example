# Copy to backend/.env and fill in your values

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Authentication — required in production
APP_PASSWORD=your-secret-password-here
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Optional: override the Claude model (default: claude-sonnet-4-6)
# Use claude-opus-4-6 for richer arrangements (slower + more expensive)
# CLAUDE_MODEL=claude-opus-4-6
